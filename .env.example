# Server-only key for YouTube Data API v3. Never expose this value in client code.
YOUTUBE_API_KEY=

# Optional public fallback used only when automatic YouTube lookup fails.
# Do not invent an ID; configure only an official El Vacío video ID.
NEXT_PUBLIC_YOUTUBE_FALLBACK_VIDEO_ID=

# Public Supabase configuration for the unauthenticated community forum.
# Use the Publishable Key, never service_role.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
